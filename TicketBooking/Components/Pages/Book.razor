@page "/book/{EventId:int}"
@using TicketBooking.Services
@using TicketBooking.Models
@using TicketBooking.DTOs.Events
@rendermode InteractiveServer
@inject IEventService EventService
@inject NavigationManager Navigation

<PageTitle>Tickets Boeken</PageTitle>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
                    <h3 class="fw-bold text-primary mb-0">Tickets Boeken</h3>
                </div>
                <div class="card-body p-4">
                    @if (geselecteerdEvent == null && string.IsNullOrEmpty(foutmelding))
                    {
                        <div class="d-flex justify-content-center my-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Evenement laden...</span>
                            </div>
                        </div>
                    }
                    else if (geselecteerdEvent != null)
                    {
                        <div class="p-3 bg-light rounded-3 mb-4 border">
                            <h4 class="mb-1 text-dark fw-bold">@geselecteerdEvent.Name</h4>
                            <div class="d-flex align-items-center mt-2">
                                <span class="me-2 text-muted">Beschikbaarheid:</span>
                                <span class="badge bg-primary rounded-pill px-3 py-2">@geselecteerdEvent.AvailableTickets tickets</span>
                            </div>
                        </div>

                        <div class="form-floating mb-3">
                            <input type="email" class="form-control rounded-3" id="emailInput" placeholder="naam@email.com" @bind="bookingDto.email" />
                            <label for="emailInput">E-mailadres</label>
                        </div>

                        <div class="form-floating mb-4">
                            <input type="number" class="form-control rounded-3" id="quantityInput" min="1" max="4" @bind="bookingDto.quantity" />
                            <label for="quantityInput">Aantal tickets (max. 4)</label>
                        </div>

                        <button class="btn btn-primary w-100 py-3 rounded-3 fw-bold shadow-sm transition-all" @onclick="BevestigBoeking" disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Bezig met verwerken...</span>
                            }
                            else
                            {
                                <span>Bevestig Boeking</span>
                            }
                        </button>
                    }

                    @if (!string.IsNullOrEmpty(foutmelding))
                    {
                        <div class="alert alert-danger mt-4 mb-0 rounded-3 border-0 shadow-sm d-flex align-items-center">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @foutmelding
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int EventId { get; set; }

    private Event? geselecteerdEvent;
    private BookEventDto bookingDto = new BookEventDto { quantity = 1 };

    private string foutmelding = "";
    private bool isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        geselecteerdEvent = await EventService.GetEventByIdAsync(EventId);

        if (geselecteerdEvent == null)
        {
            foutmelding = "Het opgevraagde evenement bestaat niet.";
        }
    }

    private async Task BevestigBoeking()
    {
        foutmelding = "";
        isSubmitting = true;

        try
        {
            await EventService.BookEventAsync(EventId, bookingDto);
            Navigation.NavigateTo("/events");
        }
        catch (Exception ex)
        {
            foutmelding = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}